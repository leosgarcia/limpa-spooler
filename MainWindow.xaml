<Window x:Class="LimpaSpooler.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Limpeza de Spooler de Impressão" Height="450" Width="600"
        Background="#1E1E1E" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Utilitário de Limpeza do Spooler" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20" 
                   Foreground="#00A8FF" HorizontalAlignment="Center"/>
                   
        <Button Grid.Row="1" x:Name="BtnClean" Content="Limpar Fila de Impressão" 
                FontSize="18" FontWeight="SemiBold" Height="50" Margin="0,0,0,20"
                Background="#007ACC" Foreground="White" BorderThickness="0"
                Click="BtnClean_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
        
        <TextBox Grid.Row="2" x:Name="TxtLog" 
                 Background="#2D2D30" Foreground="#00FF00" 
                 FontFamily="Consolas" FontSize="14"
                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                 TextWrapping="Wrap" Padding="10">
            <TextBox.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </TextBox.Resources>
        </TextBox>
    </Grid>
</Window>
